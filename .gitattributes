# 自动检测文本文件并标准化换行符
* text=auto

# 二进制文件不做换行符转换
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.bin binary
*.zip binary
*.tar.gz binary

# HarmonyOS/ArkTS 源文件
*.ets text eol=lf
*.ts text eol=lf
*.js text eol=lf
*.json text eol=lf
*.json5 text eol=lf

# 配置文件
*.yml text eol=lf
*.yaml text eol=lf
*.md text eol=lf
